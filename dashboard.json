{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "title": "🖥️ GPU Monitoring - nvtop Exporter",
  "uid": "nvtop-gpu-dashboard",
  "editable": true,
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "device",
        "type": "query",
        "datasource": { "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(nvtop_gpu_utilization_percent, device)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "🔥 GPU Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 5, "x": 0, "y": 0 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "nvtop_gpu_utilization_percent{device=~\"$device\"}",
          "legendFormat": "{{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "🧠 Memory Utilization",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 5, "x": 5, "y": 0 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "nvtop_mem_utilization_percent{device=~\"$device\"}",
          "legendFormat": "{{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "🌡️ Temperature",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 5, "x": 10, "y": 0 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "nvtop_temperature_celsius{device=~\"$device\"}",
          "legendFormat": "{{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "💨 Fan Speed",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 5, "x": 15, "y": 0 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "nvtop_fan_speed_percent{device=~\"$device\"}",
          "legendFormat": "{{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "⚡ Power Draw",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "nvtop_power_draw_watts{device=~\"$device\"}",
          "legendFormat": "{{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "min": 0,
          "max": 400,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 250 },
              { "color": "red", "value": 340 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "📈 GPU Utilization Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "nvtop_gpu_utilization_percent{device=~\"$device\"}",
          "legendFormat": "GPU Util — {{device}}"
        },
        {
          "expr": "nvtop_mem_utilization_percent{device=~\"$device\"}",
          "legendFormat": "Mem Util — {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 7,
      "title": "🌡️ Thermals & Power Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "nvtop_temperature_celsius{device=~\"$device\"}",
          "legendFormat": "Temp — {{device}}"
        },
        {
          "expr": "nvtop_fan_speed_percent{device=~\"$device\"}",
          "legendFormat": "Fan — {{device}}"
        },
        {
          "expr": "nvtop_power_draw_watts{device=~\"$device\"}",
          "legendFormat": "Power — {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "Temp" },
            "properties": [{ "id": "unit", "value": "celsius" }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "Fan" },
            "properties": [{ "id": "unit", "value": "percent" }]
          },
          {
            "matcher": { "id": "byRegexp", "options": "Power" },
            "properties": [{ "id": "unit", "value": "watt" }]
          }
        ]
      }
    },
    {
      "id": 8,
      "title": "💾 Memory Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "nvtop_mem_used_bytes{device=~\"$device\"}",
          "legendFormat": "Used — {{device}}"
        },
        {
          "expr": "nvtop_mem_total_bytes{device=~\"$device\"}",
          "legendFormat": "Total — {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "Total" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      }
    },
    {
      "id": 9,
      "title": "⏱️ Clock Speeds Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "nvtop_gpu_clock_mhz{device=~\"$device\"}",
          "legendFormat": "GPU Clock — {{device}}"
        },
        {
          "expr": "nvtop_mem_clock_mhz{device=~\"$device\"}",
          "legendFormat": "Mem Clock — {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rotmhz",
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        }
      }
    }
  ],
  "schemaVersion": 39
}
